<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Static base layer for MaterialTheme. Pulled into both mergedpages.v1.xaml and
		mergedpages.v2.xaml by the Uno.XamlMerge task (via the Styles\Application\Common\
		glob) so that a single Source=mergedpages.<ver>.xaml on BaseTheme brings in every
		default converter / colour / typography / font resource the theme needs.

		Order matters: entries listed LATER win at lookup time (MergedDictionaries are
		searched in reverse).

		Dynamic and override layers (generated spacing/shape/density scales, the seed
		palette and consumer-supplied font/colour overrides) are still added
		programmatically by BaseTheme.UpdateSource so they sit ABOVE this layer.
	-->

	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="ms-appx:///Uno.Themes.WinUI/Styles/Applications/Common/Converters.xaml" />
		<ResourceDictionary Source="ms-appx:///Uno.Themes.WinUI/Styles/Applications/Common/SharedTypography.xaml" />
		<ResourceDictionary Source="ms-appx:///Uno.Themes.WinUI/Styles/Applications/Common/SharedColorPalette.xaml" />
		<ResourceDictionary Source="ms-appx:///Uno.Themes.WinUI/Styles/Applications/Common/SharedColors.xaml" />

		<ResourceDictionary Source="ms-appx:///Uno.Material.WinUI/Styles/Application/Common/Fonts.xaml" />
	</ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
